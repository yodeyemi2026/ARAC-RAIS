IsStochastic<-function(M,tol=0.01){
  TestMatrix<-apply(M,MARGIN=c(1,3),FUN=function(x) return(abs(sum(x)-1)<=tol)) #are row-sums sufficiently close to 1 (within tolerance "tol")
  ErrorMatrix<-apply(M,MARGIN=c(1,3),FUN=function(x) return(sum(x)-1)) #Used to show the degree to which "tol" is violoated by each element.
  OK<-(length(TestMatrix[TestMatrix==FALSE])==0) #If all elements of TestMatrix are TRUE, then we are ok
  if(OK) {
    print("TM Check OK")
  }
  else {
    print("One or more probabilites are invalid, see output below for States and Age Categories marked FALSE")
    print("The total probability OUT of these states do not sum to 1 (within allowable tolerance)")
    print(TestMatrix) #print out TestMatrix for diagnostics
    print("The magnitude and direction of the violations are given below. You can adjust 'tol' parameter in IsStochastic function to a higher value if the observed error is not significant")
    print(ErrorMatrix) #show how badly the errors were
