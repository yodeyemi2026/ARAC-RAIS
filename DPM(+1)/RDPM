#Acceptance-rejection algorithm for producing non-zero gaussian random vectors subject to a linear upper bound 
LinConstGaussian<-function(N,M,COVAR,a,b,L=1){
  C<-0 #counts the number of successfully generated random vectors
  X<-array(dim=c(N,length(M)),0) #array to hold the accepted random vectors
  
  #keep generating random vectors until we've accepted N vectors.
  aid<-aid+1
  time_check<-rbind(time_check,data.frame("aId"=aid, "activity"="generate random vectors","time"=Sys.time()))
  
  while(C<N){
       K<-NULL #will hold the currently generated set of trial solutions
       
       #keep generating sets of random vectors until we get at least one acceptable vector
       while(length(K)==0){
         K<-rtmvnorm(n=N,mean=M,sigma=diag(length(M))*COVAR,a,b,algorithm="rejection") #generate N multivariate gaussian vectors constrained between a and b.
         # The vectors have Covariance matrix =  I*COVAR, where I=Identity Matrix, COVAR=vector of variances from ModSpecFile.xlsx
         B<-rowSums(K) #calculate the sum of each generated vector
         S<-(B<=L)*seq(1:length(B)) # Which vectors in B do not violate the linear constraint? Save indices to S
         K<-K[S[S>0],,drop=F] #Keep the vectors at positions given in S
       }
     #Now that we have at least one successful vector
     v<-min(length(K[,1]),N-C) #determine how many vectors we need to keep to get a total of N accepted vectors
     H<-K[sample(1:nrow(K),v),,drop=F] #if we don't need them all, then choose a random sample of the accepted vectors to store in H. #Note 6/19/2023: this is where old and new server are different
     X[(C+1):(C+v),]<-H[1:v,] #add the vectors in H to our overall results array, X.
     C<-C+v #update the total number of accepted vectors       
   }
  return(t(X))   
}

